{
  "manifest_version": 3,
  "name": "Youtube Language Level Analyzer",
  "version": "1.3.1",
  "description": "Analyze YouTube video transcripts to determine CEFR language level (A1-C2) using local AI",
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://www.youtube.com/*", "https://youtube-transcript.ai/*", "https://kome.ai/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Level"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
